---
import Layout from '~/layouts/PageLayout.astro';

import Features from '~/components/widgets/Features.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Button from '~/components/ui/Button.astro';
import ContactModal from '~/components/widgets/ContactModal.astro';

const metadata = {
  title: 'FlexPick — Affordable Partnership to Boost Your Business',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Grain Overlay -->
  <div class="fixed inset-0 pointer-events-none z-[100]" aria-hidden="true">
    <svg class="w-full h-full opacity-[0.022]" xmlns="http://www.w3.org/2000/svg">
      <filter id="grain-filter">
        <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"></feTurbulence>
      </filter>
      <rect width="100%" height="100%" filter="url(#grain-filter)"></rect>
    </svg>
  </div>

  <!-- ======== PAGE-WIDE GRID BACKGROUND ======== -->
  <div class="fixed inset-0 pointer-events-none z-0" aria-hidden="true">
    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(rgba(212,168,83,0.04) 1px, transparent 1px), linear-gradient(90deg, rgba(212,168,83,0.04) 1px, transparent 1px); background-size: 72px 72px;"
    >
    </div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_transparent_40%,_rgb(10,10,10)_85%)]"></div>
  </div>

  <!-- ======== HERO ======== -->
  <section class="relative md:-mt-[76px] not-prose overflow-hidden" id="hero">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
      <div class="pt-0 md:pt-[76px]"></div>
      <div class="py-16 md:py-24 lg:py-32">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <!-- Left: Text content -->
          <div
            class="max-w-2xl intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          >
            <div class="w-10 h-[2px] bg-primary mb-8"></div>
            <h1
              class="text-4xl sm:text-5xl md:text-6xl lg:text-[3.5rem] xl:text-[4rem] font-heading font-bold leading-[1.08] tracking-tight mb-6"
            >
              Affordable partnership to
              <span class="text-primary"> boost</span> your business needs
            </h1>
            <p class="text-lg md:text-xl text-muted max-w-lg mb-10 leading-relaxed">
              A dedicated team with all the skills you need — from kickoff to launch and beyond. Stop searching the
              market. Start building.
            </p>
            <div class="flex flex-wrap gap-4">
              <Button variant="primary" text="State your intention" href="#contact" icon="tabler:arrow-right" />
              <Button variant="secondary" text="Services" href="#services" />
            </div>
          </div>

          <!-- Right: Geometric composition -->
          <div class="hidden lg:flex justify-center items-center" aria-hidden="true">
            <div class="relative w-full max-w-md">
              <!-- Subtle glow -->
              <div
                class="absolute inset-0 bg-[radial-gradient(circle_at_center,_rgba(212,168,83,0.06)_0%,_transparent_65%)]"
              >
              </div>
              <svg viewBox="0 0 500 500" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full text-primary">
                <!-- Outer circles – slow counter-rotation -->
                <g class="geo-spin-slow">
                  <circle cx="250" cy="250" r="230" stroke="currentColor" stroke-width="0.4" opacity="0.1"></circle>
                </g>
                <g class="geo-spin-slow-reverse">
                  <circle cx="250" cy="250" r="180" stroke="currentColor" stroke-width="0.4" opacity="0.07"></circle>
                </g>

                <!-- Diamond (rotated square) – continuous rotation -->
                <g class="geo-spin-diamond">
                  <rect
                    x="105"
                    y="105"
                    width="290"
                    height="290"
                    transform="rotate(45 250 250)"
                    stroke="currentColor"
                    stroke-width="0.8"
                    opacity="0.18"></rect>
                </g>

                <!-- Inner square – subtle reverse rotation -->
                <g class="geo-spin-inner">
                  <rect x="175" y="175" width="150" height="150" stroke="currentColor" stroke-width="0.6" opacity="0.12"
                  ></rect>
                </g>

                <!-- Cross-hairs (static anchor) -->
                <line x1="250" y1="20" x2="250" y2="480" stroke="currentColor" stroke-width="0.4" opacity="0.08"></line>
                <line x1="20" y1="250" x2="480" y2="250" stroke="currentColor" stroke-width="0.4" opacity="0.08"></line>

                <!-- Accent arcs – pulsing opacity -->
                <path
                  d="M 345 95 A 205 205 0 0 1 405 250"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  class="geo-pulse-arc"></path>
                <path
                  d="M 95 355 A 205 205 0 0 0 250 410"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  class="geo-pulse-arc-alt"></path>

                <!-- Corner brackets of inner square -->
                <g class="geo-spin-inner">
                  <path d="M 175 188 L 175 175 L 188 175" stroke="currentColor" stroke-width="1.5" opacity="0.35"
                  ></path>
                  <path d="M 312 175 L 325 175 L 325 188" stroke="currentColor" stroke-width="1.5" opacity="0.35"
                  ></path>
                  <path d="M 325 312 L 325 325 L 312 325" stroke="currentColor" stroke-width="1.5" opacity="0.35"
                  ></path>
                  <path d="M 188 325 L 175 325 L 175 312" stroke="currentColor" stroke-width="1.5" opacity="0.35"
                  ></path>
                </g>

                <!-- Dashed circle – reverse rotation -->
                <g class="geo-spin-dashed">
                  <circle
                    cx="250"
                    cy="250"
                    r="100"
                    stroke="currentColor"
                    stroke-width="0.4"
                    opacity="0.1"
                    stroke-dasharray="6 6"></circle>
                </g>

                <!-- Center dot – breathing pulse -->
                <circle cx="250" cy="250" r="3.5" fill="currentColor" class="geo-pulse-dot"></circle>

                <!-- Cardinal dots -->
                <circle cx="250" cy="175" r="2" fill="currentColor" opacity="0.35"></circle>
                <circle cx="250" cy="325" r="2" fill="currentColor" opacity="0.35"></circle>
                <circle cx="175" cy="250" r="2" fill="currentColor" opacity="0.35"></circle>
                <circle cx="325" cy="250" r="2" fill="currentColor" opacity="0.35"></circle>

                <!-- Diamond corner dots – orbiting -->
                <g class="geo-spin-slow">
                  <circle cx="250" cy="45" r="2.5" fill="currentColor" opacity="0.2"></circle>
                  <circle cx="455" cy="250" r="2.5" fill="currentColor" opacity="0.2"></circle>
                  <circle cx="250" cy="455" r="2.5" fill="currentColor" opacity="0.2"></circle>
                  <circle cx="45" cy="250" r="2.5" fill="currentColor" opacity="0.2"></circle>
                </g>

                <!-- Satellite dots – drifting -->
                <circle cx="350" cy="140" r="1.5" fill="currentColor" class="geo-float-a"></circle>
                <circle cx="140" cy="350" r="1.5" fill="currentColor" class="geo-float-b"></circle>
                <circle cx="360" cy="360" r="1.5" fill="currentColor" class="geo-float-c"></circle>
                <circle cx="140" cy="140" r="1.5" fill="currentColor" class="geo-float-d"></circle>
              </svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== WHAT WE OFFER ======== -->
  <Features
    id="services"
    tagline="Services"
    title="What working with us actually looks like"
    subtitle=""
    columns={3}
    items={[
      {
        title: 'Free consultation & estimation',
        description:
          'We turn your ideas into a tech spec and a realistic budget. No fluff, no surprises — just a clear picture of what it takes.',
        icon: 'tabler:message-circle',
      },
      {
        title: 'Continuous project maintenance',
        description:
          "Book any slot during or after development. We don't disappear after launch — we're always a message away.",
        icon: 'tabler:refresh',
      },
      {
        title: 'AI-powered development',
        description:
          'We integrate AI into every stage of the process — from intelligent code generation and automated testing to AI-driven analytics and smart features baked into your product.',
        icon: 'tabler:brain',
      },
      {
        title: 'Monthly support packages',
        description:
          'Fixed-price packages for small businesses that need steady, affordable help without committing to a full engagement.',
        icon: 'tabler:calendar-check',
      },
      {
        title: 'Long-term cooperation discounts',
        description:
          'Trust compounds. The longer we work together, the better we understand your product — and the more you save.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Hosting & server setup',
        description:
          'We recommend and configure the right infrastructure for your project type and budget. No over-engineering, no under-provisioning.',
        icon: 'tabler:server',
      },
    ]}
    classes={{
      container: 'max-w-6xl',
      headline: {
        container: 'mb-12 md:mb-16',
        tagline: 'text-primary',
      },
      items: {
        panel:
          'feature-card border border-white/[0.06] rounded-lg p-6 bg-white/[0.015] hover:bg-white/[0.04] hover:-translate-y-1 transition-all duration-300 max-w-none',
        icon: 'feature-icon text-primary bg-primary/10 rounded-lg w-10 h-10 p-2 md:w-11 md:h-11 md:p-2.5 mr-4',
        title: 'text-base font-semibold',
        description: 'text-sm leading-relaxed',
      },
    }}
  />

  <!-- ======== HOW IT WORKS ======== -->
  <section id="how-it-works" class="relative py-16 md:py-20 scroll-mt-[72px] not-prose">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <!-- Section header -->
      <div
        class="text-center mb-14 md:mb-20 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Process</p>
        <h2 class="text-3xl md:text-4xl font-heading font-bold tracking-tight">Simple process. No agency fluff.</h2>
      </div>

      <!-- Steps grid -->
      <div class="grid md:grid-cols-3 gap-10 md:gap-8 lg:gap-12 relative">
        <!-- Connecting line (desktop) -->
        <div
          class="hidden md:block absolute top-[2.2rem] left-[20%] right-[20%] h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"
          aria-hidden="true"
        >
        </div>

        <!-- Step 1 -->
        <div
          class="process-step relative intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
        >
          <div class="mb-5">
            <span class="step-number text-6xl font-heading font-bold text-primary/15 leading-none">01</span>
          </div>
          <h3 class="text-lg font-bold mb-3">You reach out</h3>
          <p class="text-muted text-[0.925rem] leading-relaxed">
            We schedule a free 30-minute discovery call to understand your vision, goals, and constraints. No pressure,
            no pitch deck.
          </p>
        </div>

        <!-- Step 2 -->
        <div
          class="process-step relative intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          style="--tw-animation-delay: 0.15s; animation-delay: 0.15s;"
        >
          <div class="mb-5">
            <span class="step-number text-6xl font-heading font-bold text-primary/15 leading-none">02</span>
          </div>
          <h3 class="text-lg font-bold mb-3">We scope it together</h3>
          <p class="text-muted text-[0.925rem] leading-relaxed">
            Clear estimate, realistic timeline, and team assignment. No surprises, no bloated quotes — just an honest
            plan.
          </p>
        </div>

        <!-- Step 3 -->
        <div
          class="process-step relative intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          style="--tw-animation-delay: 0.3s; animation-delay: 0.3s;"
        >
          <div class="mb-5">
            <span class="step-number text-6xl font-heading font-bold text-primary/15 leading-none">03</span>
          </div>
          <h3 class="text-lg font-bold mb-3">We build</h3>
          <p class="text-muted text-[0.925rem] leading-relaxed">
            With full transparency, regular check-ins, and zero ghosting. You're never left wondering what's happening
            with your project.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== WHY FLEXPICK ======== -->
  <section class="relative py-16 md:py-20 scroll-mt-[72px] not-prose">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <!-- Section header -->
      <div
        class="text-center mb-14 md:mb-20 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Trust</p>
        <h2 class="text-3xl md:text-4xl font-heading font-bold tracking-tight">Why teams choose us</h2>
      </div>

      <!-- Trust signals -->
      <div
        class="grid md:grid-cols-3 gap-10 md:gap-0 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <div class="trust-card md:px-8 md:first:pl-0 md:border-r md:border-white/[0.06] rounded-lg p-4 md:p-6">
          <div class="trust-accent w-8 h-[2px] bg-primary/60 mb-6"></div>
          <p class="text-lg font-semibold leading-snug mb-3">Referral-only client base</p>
          <p class="text-muted text-[0.925rem] leading-relaxed">
            Our reputation is our pipeline. Every client comes through a trusted recommendation — that's how we know
            we're doing it right.
          </p>
        </div>
        <div class="trust-card md:px-8 md:border-r md:border-white/[0.06] rounded-lg p-4 md:p-6">
          <div class="trust-accent w-8 h-[2px] bg-primary/60 mb-6"></div>
          <p class="text-lg font-semibold leading-snug mb-3">9+ years of combined experience</p>
          <p class="text-muted text-[0.925rem] leading-relaxed">
            Engineering expertise across web, mobile, and integrations — built on real-world delivery, not
            certifications on a wall.
          </p>
        </div>
        <div class="trust-card md:px-8 md:last:pr-0 rounded-lg p-4 md:p-6">
          <div class="trust-accent w-8 h-[2px] bg-primary/60 mb-6"></div>
          <p class="text-lg font-semibold leading-snug mb-3">Fixed-price options available</p>
          <p class="text-muted text-[0.925rem] leading-relaxed">
            For teams that need predictable budgets. Transparent pricing with no hidden fees — you know exactly what
            you're paying for.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== PROJECT CONTROL ======== -->
  <section class="relative py-16 md:py-24 scroll-mt-[72px] not-prose overflow-hidden">
    <!-- Subtle top/bottom borders -->
    <div class="absolute inset-0 border-t border-b border-white/[0.04]" aria-hidden="true"></div>

    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Left: Copy -->
        <div class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
          <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Built-In Tooling</p>
          <h2 class="text-3xl md:text-4xl font-heading font-bold tracking-tight mb-6">
            Full project visibility.<br />Zero extra cost.
          </h2>
          <p class="text-muted text-[0.95rem] leading-relaxed mb-8 max-w-lg">
            Every engagement includes access to our customizable task and time tracking system — purpose-built to give
            you complete control over internal processes from the first commit to final delivery.
          </p>

          <div class="space-y-5">
            <div class="flex items-start gap-4 group">
              <div
                class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors duration-300"
              >
                <svg
                  class="w-4.5 h-4.5 text-primary"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-[0.95rem] mb-1">Task boards tailored to your workflow</p>
                <p class="text-muted text-sm leading-relaxed">
                  Kanban, list, or timeline — configured to match how your team actually works, not how a tool thinks
                  you should.
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4 group">
              <div
                class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors duration-300"
              >
                <svg
                  class="w-4.5 h-4.5 text-primary"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                  ></path>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-[0.95rem] mb-1">Real-time tracking per task</p>
                <p class="text-muted text-sm leading-relaxed">
                  See exactly where hours go. Every task carries logged time so you always know the cost of each
                  feature.
                </p>
              </div>
            </div>

            <div class="flex items-start gap-4 group">
              <div
                class="w-9 h-9 rounded-lg bg-primary/10 flex items-center justify-center shrink-0 group-hover:bg-primary/20 transition-colors duration-300"
              >
                <svg
                  class="w-4.5 h-4.5 text-primary"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                </svg>
              </div>
              <div>
                <p class="font-semibold text-[0.95rem] mb-1">No third-party fees</p>
                <p class="text-muted text-sm leading-relaxed">
                  Forget Jira licenses and tool sprawl. Everything lives under one roof — included in your engagement at
                  no additional cost.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Stylized dashboard mockup -->
        <div
          class="hidden lg:block intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          style="--tw-animation-delay: 0.2s; animation-delay: 0.2s;"
          aria-hidden="true"
        >
          <div class="relative">
            <!-- Ambient glow -->
            <div
              class="absolute -inset-8 bg-[radial-gradient(circle_at_center,_rgba(212,168,83,0.04)_0%,_transparent_70%)]"
            >
            </div>

            <!-- Dashboard frame -->
            <div
              class="relative border border-white/[0.08] rounded-xl bg-white/[0.02] overflow-hidden shadow-2xl shadow-black/20"
            >
              <!-- Title bar -->
              <div class="flex items-center gap-2 px-4 py-3 border-b border-white/[0.06] bg-white/[0.02]">
                <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-white/10"></div>
                <span class="ml-3 text-xs text-muted font-medium tracking-wide">FlexPick — Project Dashboard</span>
              </div>

              <!-- Dashboard content -->
              <div class="p-5 space-y-4">
                <!-- Stats row -->
                <div class="grid grid-cols-3 gap-3">
                  <div class="border border-white/[0.06] rounded-lg p-3 bg-white/[0.015] dash-stat">
                    <p class="text-xs text-muted mb-1">Tasks</p>
                    <p class="text-xl font-heading font-bold text-primary">24</p>
                    <p class="text-[0.7rem] text-muted mt-0.5">6 in progress</p>
                  </div>
                  <div
                    class="border border-white/[0.06] rounded-lg p-3 bg-white/[0.015] dash-stat"
                    style="--tw-animation-delay: 0.1s; animation-delay: 0.1s;"
                  >
                    <p class="text-xs text-muted mb-1">Hours</p>
                    <p class="text-xl font-heading font-bold">142<span class="text-sm text-muted">.5h</span></p>
                    <p class="text-[0.7rem] text-muted mt-0.5">this sprint</p>
                  </div>
                  <div
                    class="border border-white/[0.06] rounded-lg p-3 bg-white/[0.015] dash-stat"
                    style="--tw-animation-delay: 0.2s; animation-delay: 0.2s;"
                  >
                    <p class="text-xs text-muted mb-1">Progress</p>
                    <p class="text-xl font-heading font-bold text-green-400">78%</p>
                    <p class="text-[0.7rem] text-muted mt-0.5">on track</p>
                  </div>
                </div>

                <!-- Task list -->
                <div class="border border-white/[0.06] rounded-lg overflow-hidden">
                  <div class="px-3 py-2 border-b border-white/[0.06] bg-white/[0.02]">
                    <p class="text-xs font-semibold tracking-wide text-muted uppercase">Active Tasks</p>
                  </div>
                  <div class="divide-y divide-white/[0.04]">
                    <div class="flex items-center gap-3 px-3 py-2.5 dash-row hover:bg-white/[0.02] transition-colors">
                      <div class="w-1.5 h-1.5 rounded-full bg-primary"></div>
                      <span class="text-xs flex-1">Implement user auth flow</span>
                      <span class="text-[0.65rem] text-primary/70 font-medium">4.5h</span>
                    </div>
                    <div class="flex items-center gap-3 px-3 py-2.5 dash-row hover:bg-white/[0.02] transition-colors">
                      <div class="w-1.5 h-1.5 rounded-full bg-blue-400"></div>
                      <span class="text-xs flex-1">Design payment integration</span>
                      <span class="text-[0.65rem] text-blue-400/70 font-medium">2.0h</span>
                    </div>
                    <div class="flex items-center gap-3 px-3 py-2.5 dash-row hover:bg-white/[0.02] transition-colors">
                      <div class="w-1.5 h-1.5 rounded-full bg-green-400"></div>
                      <span class="text-xs flex-1">API endpoint testing</span>
                      <span class="text-[0.65rem] text-green-400/70 font-medium">1.5h</span>
                    </div>
                    <div class="flex items-center gap-3 px-3 py-2.5 dash-row hover:bg-white/[0.02] transition-colors">
                      <div class="w-1.5 h-1.5 rounded-full bg-amber-400"></div>
                      <span class="text-xs flex-1">Mobile responsive fixes</span>
                      <span class="text-[0.65rem] text-amber-400/70 font-medium">3.0h</span>
                    </div>
                  </div>
                </div>

                <!-- Progress bar -->
                <div class="pt-1">
                  <div class="flex justify-between text-[0.7rem] text-muted mb-2">
                    <span>Sprint progress</span>
                    <span>78%</span>
                  </div>
                  <div class="h-1.5 rounded-full bg-white/[0.06] overflow-hidden">
                    <div
                      class="h-full rounded-full bg-gradient-to-r from-primary/80 to-primary dash-progress-bar"
                      style="width: 78%"
                    >
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ======== FAQ ======== -->
  <FAQs
    id="faq"
    title="There are no awkward questions."
    tagline="FAQ"
    columns={1}
    classes={{
      container: 'max-w-3xl',
      headline: {
        tagline: 'text-primary',
        container: 'mb-12 md:mb-16',
      },
    }}
    items={[
      {
